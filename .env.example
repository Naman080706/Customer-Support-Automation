# ---------------------------------------------------------------------------
# OPTIONAL LLM configuration
# ---------------------------------------------------------------------------
# The system runs fully OFFLINE out of the box using a deterministic
# rule-based engine grounded in real RAG retrieval. If you want it to use a
# real Large Language Model instead, copy this file to ".env" and set ONE of
# the keys below. The system auto-detects the provider.
#
#   cp .env.example .env
#
# Gemini (Google) -- get a free key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# OpenAI -- get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Force a specific mode: "offline", "gemini", or "openai".
# Leave blank for automatic detection.
LLM_MODE=
